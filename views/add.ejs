<%- include('partials/header') %>

    <div class="form-wrapper">
        <div class="form-container glass">
            <h2>Add New Employee</h2>
            <p>Fill out the form below to add a new team member.</p>

            <% if (error) { %>
                <div class="alert alert-danger">
                    <%- error %>
                </div>
                <% } %>

                    <form action="/add" method="POST">
                        <div class="form-group">
                            <label for="name">Employee Name</label>
                            <input type="text" id="name" name="name"
                                value="<%= employee && employee.name ? employee.name : '' %>"
                                placeholder="Enter full name (5-20 chars)" required minlength="5" maxlength="20">
                            <small>5 - 20 characters</small>
                        </div>

                        <div class="form-group">
                            <label for="age">Age</label>
                            <input type="number" id="age" name="age"
                                value="<%= employee && employee.age ? employee.age : '' %>" placeholder="Must be > 20"
                                required min="21">
                            <small>Greater than 20</small>
                        </div>

                        <div class="form-group">
                            <label for="address">Address</label>
                            <input type="text" id="address" name="address"
                                value="<%= employee && employee.address ? employee.address : '' %>"
                                placeholder="Enter address (10-40 chars)" required minlength="10" maxlength="40">
                            <small>10 - 40 characters</small>
                        </div>

                        <div class="form-group">
                            <label for="phoneNumber">Phone Number</label>
                            <input type="text" id="phoneNumber" name="phoneNumber"
                                value="<%= employee && employee.phoneNumber ? employee.phoneNumber : '' %>"
                                placeholder="Start with 08, 9-12 digits" required pattern="^08[0-9]{7,10}$">
                            <small>Starts with 08, 9-12 digits</small>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn-primary">Create Employee</button>
                            <a href="/" class="btn-text">Cancel</a>
                        </div>
                    </form>
        </div>
    </div>

    <%- include('partials/footer') %>