<%- include('partials/header') %>

    <div class="form-wrapper">
        <div class="form-container glass">
            <h2>Edit Employee</h2>
            <p>Update the information for <strong>
                    <%= employee.name %>
                </strong>.</p>

            <% if (error) { %>
                <div class="alert alert-danger">
                    <%- error %>
                </div>
                <% } %>

                    <form action="/edit/<%= employee.id %>" method="POST">
                        <div class="form-group">
                            <label for="name">Employee Name</label>
                            <input type="text" id="name" name="name" value="<%= employee.name %>"
                                placeholder="Enter full name (5-20 chars)" required minlength="5" maxlength="20">
                            <small>5 - 20 characters</small>
                        </div>

                        <div class="form-group">
                            <label for="age">Age</label>
                            <input type="number" id="age" name="age" value="<%= employee.age %>"
                                placeholder="Must be > 20" required min="21">
                            <small>Greater than 20</small>
                        </div>

                        <div class="form-group">
                            <label for="address">Address</label>
                            <input type="text" id="address" name="address" value="<%= employee.address %>"
                                placeholder="Enter address (10-40 chars)" required minlength="10" maxlength="40">
                            <small>10 - 40 characters</small>
                        </div>

                        <div class="form-group">
                            <label for="phoneNumber">Phone Number</label>
                            <input type="text" id="phoneNumber" name="phoneNumber" value="<%= employee.phoneNumber %>"
                                placeholder="Start with 08, 9-12 digits" required pattern="^08[0-9]{7,10}$">
                            <small>Starts with 08, 9-12 digits</small>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn-primary">Update Details</button>
                            <a href="/" class="btn-text">Cancel</a>
                        </div>
                    </form>
        </div>
    </div>

    <%- include('partials/footer') %>